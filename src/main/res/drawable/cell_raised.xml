<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#7b7b7b" /> <!-- Dark Shadow (Bottom/Right) -->
        </shape>
    </item>
    <item android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#ffffff" /> <!-- Light Highlight (Top/Left) -->
        </shape>
    </item>
    <item android:bottom="3dp" android:left="3dp" android:right="3dp" android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#bdbdbd" /> <!-- Surface -->
        </shape>
    </item>
</layer-list>
